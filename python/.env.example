# StockForensics : copy to .env and fill secrets. Bootstrap works offline without these;
# live stages degrade gracefully when a key is absent (Q7).

# Gatekeeping: set a strong random string; frontend must send X-Api-Key header.
# Leave empty to disable auth (local dev / offline use).
API_KEY=

# SEC requires a descriptive User-Agent with contact email (NOT secret, but required).
SEC_USER_AGENT="StockForensics research <you@example.com>"

# Universe / batch sizing
TOP_N=25
UNIVERSE_AUTO_REFRESH=true

# Gemini (LLM + embeddings)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_RPM=10

# Pinecone (vector store) : index lazy-created on first live run
PINECONE_API_KEY=
PINECONE_INDEX=stockforensics
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Web/news search is done via Gemini's built-in google_search grounding (no Tavily).

# Live market-data polling on the detail view (market-hours gated)
POLL_INTERVAL_S=10
POLL_MAX=60

# Cache invalidation: bump to invalidate all LLM outputs
PROMPT_VERSION=1

# Storage
SQLITE_PATH=data/stockforensics.db
LOG_LEVEL=INFO
LOG_JSON=true
